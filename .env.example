KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_HOST_ADVERTISED_LISTENER=127.0.0.1:9092
KAFKA_TOPIC_NAME=customer_heartbeats
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_ENABLE_IDEMPOTENCE=true
KAFKA_PRODUCER_RETRIES=10
KAFKA_PRODUCER_DELIVERY_TIMEOUT_MS=120000
KAFKA_PRODUCER_LINGER_MS=20
SIMULATION_INTERVAL_SECONDS=1.0
TOTAL_CUSTOMERS=5
HOST_BIND_ADDRESS=127.0.0.1
LOG_LEVEL=INFO
CONSUMER_RETRY_BACKOFF_SECONDS=2.0
DB_CONNECT_RETRIES=5
DB_CONNECT_BACKOFF_SECONDS=2.0
PRODUCER_BUFFER_RETRY_BACKOFF_SECONDS=1.0

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=heartbeat_db
DB_USER=heartbeat_app
DB_PASSWORD=replace-with-a-strong-password

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password
